---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

const reportsDir = path.join(process.cwd(), '..', 'reports');
const weeklyPath = path.join(reportsDir, 'weekly-latest.md');

let content = '';
try {
  content = fs.readFileSync(weeklyPath, 'utf-8');
} catch (e) {
  content = '# Weekly Summary\n\n>No weekly summary generated yet. Reports are aggregated every Monday.';
}

// Parse the weekly markdown into sections
function parseWeekly(md: string) {
  const sections: { title: string; level: number; content: string; emoji: string }[] = [];
  const lines = md.split('\n');
  let currentSection: typeof sections[0] | null = null;

  for (const line of lines) {
    const headerMatch = line.match(/^(#{1,3})\s+(.*)/);
    if (headerMatch) {
      if (currentSection) sections.push(currentSection);
      const title = headerMatch[2].trim();
      const level = headerMatch[1].length;
      const emojiMatch = title.match(/^(🔥|📊|🏷️|📅)\s*/);
      const emoji = emojiMatch ? emojiMatch[1] : '';
      const cleanTitle = title.replace(/^(🔥|📊|🏷️|📅)\s*/, '');
      currentSection = { title: cleanTitle, level, content: '', emoji };
    } else if (currentSection) {
      currentSection.content += line + '\n';
    }
  }
  if (currentSection) sections.push(currentSection);
  return sections;
}

function parseContent(content: string) {
  const items: { type: string; text: string; title?: string; link?: string; source?: string; date?: string; summary?: string }[] = [];
  const lines = content.trim().split('\n');

  for (let i = 0; i < lines.length; i++) {
    const line = lines[i].trim();

    // Numbered list with link: 1. **[Title](url)** 🔴
    const topMatch = line.match(/^\d+\.\s*\*\*\[(.+)\]\((https?:\/\/[^)]+)\)\*\*\s*(🔴|🟡|🟢|📰)/);
    if (topMatch) {
      const nextLine = lines[i + 1]?.trim() || '';
      const sourceMatch = nextLine.match(/— \*(.*?)\* · (.*)/);
      const summaryLine = lines[i + 2]?.trim() || '';
      const summaryMatch = summaryLine.match(/^> (.*)/);

      items.push({
        type: 'top-story',
        title: topMatch[1],
        link: topMatch[2],
        text: topMatch[3],
        source: sourceMatch ? sourceMatch[1] : '',
        date: sourceMatch ? sourceMatch[2] : '',
        summary: summaryMatch ? summaryMatch[1] : '',
      });
      continue;
    }

    // Source breakdown: - **Source**: N articles
    const sourceMatch = line.match(/^-\s*\*\*(.*?)\*\*:\s*(\d+)\s*articles?/);
    if (sourceMatch) {
      items.push({ type: 'source', text: sourceMatch[1], title: sourceMatch[2] });
      continue;
    }

    // Plain text lines
    if (line && !line.match(/^\d+\./) && !line.match(/^-/)) {
      items.push({ type: 'text', text: line });
    }
  }

  return items;
}

const sections = parseWeekly(content);

// Extract week info from the H1
const h1Match = content.match(/^#\s+(.*)/);
const weekTitle = h1Match ? h1Match[1] : 'Weekly Summary';
const metaMatch = content.match(/\*\*(\d{4}-\d{2}-\d{2}) → (\d{4}-\d{2}-\d{2})\*\* · (\d+) reports? · (\d+) articles?/);
const weekRange = metaMatch ? `${metaMatch[1]} → ${metaMatch[2]}` : '';
const reportCount = metaMatch ? metaMatch[3] : '0';
const articleCount = metaMatch ? metaMatch[4] : '0';

// Extract stats
const statsMatch = content.match(/🔴 (\d+) Action · 🟡 (\d+) Watch · 🟢 (\d+) Learn · 📰 (\d+) FYI/);
const stats = statsMatch ? { action: statsMatch[1], watch: statsMatch[2], learn: statsMatch[3], fyi: statsMatch[4] } : null;
---

<Layout title="SEO Digest — Weekly Summary">
  <a href="/" class="back">← All reports</a>

  <div class="hero" style="padding-bottom: 1rem;">
    <div class="hero-badge" style="background: #f0fdf4; color: #16a34a;">
      <span style="width:6px;height:6px;border-radius:50%;background:#16a34a;display:inline-block;margin-right:4px;"></span>
      Weekly
    </div>
    <h1>{weekTitle}</h1>
    {weekRange && (
      <p>{weekRange} · {reportCount} reports · {articleCount} articles</p>
    )}
    {stats && (
      <div class="stats-bar">
        <span class="stat-pill"><span class="dot dot-red"></span>{stats.action} Action</span>
        <span class="stat-pill"><span class="dot dot-amber"></span>{stats.watch} Watch</span>
        <span class="stat-pill"><span class="dot dot-green"></span>{stats.learn} Learn</span>
        <span class="stat-pill"><span class="dot dot-blue"></span>{stats.fyi} FYI</span>
      </div>
    )}
  </div>

  {sections.map(section => {
    const items = parseContent(section.content);

    if (section.level === 1) return null;

    return (
      <div>
        <div class="section-header">
          <span>{section.emoji}</span>
          <h2>{section.title}</h2>
        </div>

        {section.title === 'Top Stories' && items.length > 0 ? (
          <div class="top-stories">
            {items.filter(item => item.type === 'top-story').map((item, i) => (
              <article class="card" style={{position:'relative'}}>
                <span style={{position:'absolute',right:'1.25rem',top:'1.25rem',fontSize:'1.5rem',fontWeight:800,color:'var(--border)',opacity:0.6}}>#{i + 1}</span>
                <h3><a href={item.link} target="_blank" rel="noopener">{item.title}</a></h3>
                <div class="source">
                  {item.source}
                  {item.text === '🔴' ? <span style={{marginLeft:'0.35rem'}}>🔴</span> : null}
                  {item.text === '🟡' ? <span style={{marginLeft:'0.35rem'}}>🟡</span> : null}
                  {item.text === '🟢' ? <span style={{marginLeft:'0.35rem'}}>🟢</span> : null}
                  {item.text === '📰' ? <span style={{marginLeft:'0.35rem'}}>📰</span> : null}
                </div>
                {item.summary ? <div class="summary">{item.summary}</div> : null}
              </article>
            ))}
          </div>
        ) : section.title === 'Source Breakdown' && items.length > 0 ? (
          <div class="card" style={{padding: '1rem 1.25rem'}}>
            {items.map(item => (
              item.type === 'source' ? (
                <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',padding:'0.5rem 0',borderBottom:'1px solid var(--border-light)'}}>
                  <span style={{fontWeight:600,fontSize:'0.9rem'}}>{item.text}</span>
                  <span style={{fontSize:'0.85rem',color:'var(--text-muted)',fontWeight:500}}>{item.title} articles</span>
                </div>
              ) : null
            ))}
          </div>
        ) : section.title === 'Trending Topics' ? (
          <div class="card" style={{padding: '1.25rem'}}>
            <div class="tags" style={{marginTop:0}}>
              {(section.content.match(/\x60([^\x60]+)\x60/g) || []).map(tag => (
                <span class="tag-item" style={{fontSize:'0.85rem',padding:'0.3rem 0.7rem'}}>{tag.replace(/\x60/g, '')}</span>
              ))}
            </div>
          </div>
        ) : (
          <div style={{color:'var(--text-secondary)',fontSize:'0.9rem',lineHeight:1.7}}>
            {section.content.split('\n').map(line => (
              line.trim() ? <p style={{marginBottom:'0.5rem'}}>{line.trim().replace(/^> /, '').replace(/^- /, '• ')}</p> : null
            ))}
          </div>
        )}
      </div>
    );
  })}
</Layout>
