---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

const reportsDir = path.join(process.cwd(), '..', 'reports');
let reports: { date: string; filename: string; stats: { action: number; watch: number; learn: number; fyi: number } }[] = [];

try {
  const files = fs.readdirSync(reportsDir)
    .filter(f => f.endsWith('.md'))
    .sort()
    .reverse();

  for (const file of files) {
    const content = fs.readFileSync(path.join(reportsDir, file), 'utf-8');
    const date = file.replace('.md', '');
    const actionMatch = content.match(/🔴 Action:\s*(\d+)/);
    const watchMatch = content.match(/🟡 Watch:\s*(\d+)/);
    const learnMatch = content.match(/🟢 Learn:\s*(\d+)/);
    const fyiMatch = content.match(/📰 FYI:\s*(\d+)/);

    reports.push({
      date,
      filename: file,
      stats: {
        action: parseInt(actionMatch?.[1] || '0'),
        watch: parseInt(watchMatch?.[1] || '0'),
        learn: parseInt(learnMatch?.[1] || '0'),
        fyi: parseInt(fyiMatch?.[1] || '0'),
      }
    });
  }
} catch (e) {
  console.log('No reports found yet');
}

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
};

const formatShortDate = (dateStr: string) => {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
};

const totalReports = reports.length;
const totalAction = reports.reduce((a, r) => a + r.stats.action, 0);
const totalWatch = reports.reduce((a, r) => a + r.stats.watch, 0);
const totalLearn = reports.reduce((a, r) => a + r.stats.learn, 0);
const totalFyi = reports.reduce((a, r) => a + r.stats.fyi, 0);
---

<Layout title="SEO News Digest — Daily Reports">
  <div class="hero">
    <div class="hero-badge">Live Digest</div>
    <h1>Daily SEO Digest</h1>
    <p>Twice-weekly intelligence from blogs, Reddit, and official channels.<br>Published every <strong>Tuesday</strong> and <strong>Friday</strong> at 2:30 PM IST.</p>

    {totalReports > 0 && (
      <div class="stats-bar">
        <span class="stat-pill"><span class="dot dot-red"></span>{totalAction} Action</span>
        <span class="stat-pill"><span class="dot dot-amber"></span>{totalWatch} Watch</span>
        <span class="stat-pill"><span class="dot dot-green"></span>{totalLearn} Learn</span>
        <span class="stat-pill"><span class="dot dot-blue"></span>{totalFyi} FYI</span>
      </div>
    )}
  </div>

  {totalReports === 0 ? (
    <div class="empty">
      <div class="empty-icon">📭</div>
      <h2>No reports yet</h2>
      <p>Run <code>python run.py</code> locally to generate the first report, or trigger the workflow manually from GitHub Actions.</p>
    </div>
  ) : (
    <div class="report-list">
      {reports.map((report, i) => (
        <a href={`/${report.date}`} class="report-item">
          <div class="report-item-left">
            <div class="report-item-icon">📰</div>
            <div>
              <div class="report-item-date">{formatDate(report.date)}</div>
              <div class="report-item-meta">
                {report.stats.action > 0 && `🔴 ${report.stats.action} action · `}
                {report.stats.watch > 0 && `🟡 ${report.stats.watch} watch · `}
                {report.stats.learn > 0 && `🟢 ${report.stats.learn} learn · `}
                {report.stats.fyi > 0 && `📰 ${report.stats.fyi} FYI`}
              </div>
            </div>
          </div>
          <span class="report-item-arrow">→</span>
        </a>
      ))}
    </div>
  )}
</Layout>
