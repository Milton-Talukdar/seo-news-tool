---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

// Read all reports from parent directory
const reportsDir = path.join(process.cwd(), '..', 'reports');
let reports: { date: string; filename: string; stats: { action: number; watch: number; learn: number; fyi: number } }[] = [];

try {
  const files = fs.readdirSync(reportsDir)
    .filter(f => f.endsWith('.md'))
    .sort()
    .reverse();
  
  for (const file of files) {
    const content = fs.readFileSync(path.join(reportsDir, file), 'utf-8');
    const date = file.replace('.md', '');
    
    // Parse stats from content
    const actionMatch = content.match(/🔴 Action:\s*(\d+)/);
    const watchMatch = content.match(/🟡 Watch:\s*(\d+)/);
    const learnMatch = content.match(/🟢 Learn:\s*(\d+)/);
    const fyiMatch = content.match(/📰 FYI:\s*(\d+)/);
    
    reports.push({
      date,
      filename: file,
      stats: {
        action: parseInt(actionMatch?.[1] || '0'),
        watch: parseInt(watchMatch?.[1] || '0'),
        learn: parseInt(learnMatch?.[1] || '0'),
        fyi: parseInt(fyiMatch?.[1] || '0'),
      }
    });
  }
} catch (e) {
  console.log('No reports found yet');
}

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
};

const totalReports = reports.length;
---

<Layout title="SEO News Digest — Daily Reports">
  <h1>Daily SEO Digest</h1>
  <p class="subtitle">Automated daily reports from 8 authoritative SEO sources — categorized into Action, Watch, Learn, and FYI.</p>
  
  {totalReports === 0 ? (
    <div class="empty">
      <div class="empty-icon">📭</div>
      <p>No reports generated yet.</p>
      <p style="margin-top: 0.5rem;">Run <code style="background: var(--surface-light); padding: 0.2rem 0.5rem; border-radius: 4px;">python run.py</code> locally to generate the first report, or wait for the GitHub Actions cron job.</p>
    </div>
  ) : (
    <>
      <div class="card">
        <div class="card-header">
          <span style="font-size: 1.5rem;">📊</span>
          <div>
            <div class="card-title">{totalReports} report{totalReports !== 1 ? 's' : ''} generated</div>
            <div class="card-date">Latest: {formatDate(reports[0].date)}</div>
          </div>
        </div>
        <div class="card-stats">
          <span class="stat stat-red">🔴 {reports.reduce((a, r) => a + r.stats.action, 0)} action items</span>
          <span class="stat stat-yellow">🟡 {reports.reduce((a, r) => a + r.stats.watch, 0)} watch items</span>
          <span class="stat stat-green">🟢 {reports.reduce((a, r) => a + r.stats.learn, 0)} learn items</span>
          <span class="stat stat-blue">📰 {reports.reduce((a, r) => a + r.stats.fyi, 0)} FYI items</span>
        </div>
      </div>
      
      <h2>All Reports</h2>
      <div class="report-list">
        {reports.map(report => (
          <a href={`/${report.date}`} class="report-item">
            <div class="report-item-left">
              <span style="font-size: 1.25rem;">📰</span>
              <div>
                <div class="report-item-date">{formatDate(report.date)}</div>
                <div class="report-item-meta">
                  🔴 {report.stats.action} · 🟡 {report.stats.watch} · 🟢 {report.stats.learn} · 📰 {report.stats.fyi}
                </div>
              </div>
            </div>
            <span class="report-item-arrow">→</span>
          </a>
        ))}
      </div>
    </>
  )}
</Layout>
