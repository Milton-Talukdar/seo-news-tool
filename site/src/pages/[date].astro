---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

// Generate all paths from existing reports
export function getStaticPaths() {
  const reportsDir = path.join(process.cwd(), '..', 'reports');
  const paths: { params: { date: string } }[] = [];
  
  try {
    const files = fs.readdirSync(reportsDir).filter(f => f.endsWith('.md'));
    for (const file of files) {
      paths.push({ params: { date: file.replace('.md', '') } });
    }
  } catch (e) {
    // No reports yet
  }
  
  return paths;
}

const { date } = Astro.params;
const reportsDir = path.join(process.cwd(), '..', 'reports');
const filePath = path.join(reportsDir, `${date}.md`);

let content = '';
try {
  content = fs.readFileSync(filePath, 'utf-8');
} catch (e) {
  content = '# Report not found';
}

// Parse sections from markdown
function parseReport(md: string) {
  const sections: { title: string; level: number; content: string; emoji: string }[] = [];
  const lines = md.split('\n');
  let currentSection: { title: string; level: number; content: string; emoji: string } | null = null;
  
  for (const line of lines) {
    const headerMatch = line.match(/^(#{1,3})\s+(.*)/);
    if (headerMatch) {
      if (currentSection) sections.push(currentSection);
      const title = headerMatch[2].trim();
      const level = headerMatch[1].length;
      
      // Extract emoji from title
      const emojiMatch = title.match(/^(🔴|🟡|🟢|📰|📝)\s*/);
      const emoji = emojiMatch ? emojiMatch[1] : '';
      const cleanTitle = title.replace(/^(🔴|🟡|🟢|📰|📝)\s*/, '');
      
      currentSection = { title: cleanTitle, level, content: '', emoji };
    } else if (currentSection) {
      currentSection.content += line + '\n';
    }
  }
  if (currentSection) sections.push(currentSection);
  
  return sections;
}

// Convert markdown content to HTML-like structure
function parseContent(content: string) {
  const items: { type: string; content: string; link?: string; source?: string; summary?: string; tags?: string[] }[] = [];
  const lines = content.trim().split('\n');
  
  for (let i = 0; i < lines.length; i++) {
    const line = lines[i].trim();
    
    // Article link: **[Title](url)** — *Source*
    const articleMatch = line.match(/^\*\*\[(.*?)\]\((.*?)\)\*\*\s*—\s*\*(.*?)\*/);
    if (articleMatch) {
      items.push({
        type: 'article',
        content: articleMatch[1],
        link: articleMatch[2],
        source: articleMatch[3],
      });
      continue;
    }
    
    // Summary: > text
    const summaryMatch = line.match(/^>(.*)/);
    if (summaryMatch && items.length > 0) {
      const last = items[items.length - 1];
      if (last.type === 'article') {
        last.summary = (last.summary || '') + summaryMatch[1].trim() + ' ';
      }
      continue;
    }
    
    // Tags: 🏷️ `tag1`, `tag2`
    const tagMatch = line.match(/🏷️\s*(.*)/);
    if (tagMatch && items.length > 0) {
      const last = items[items.length - 1];
      if (last.type === 'article') {
        const tagStr = tagMatch[1];
        last.tags = tagStr.match(/`([^`]+)`/g)?.map(t => t.replace(/`/g, '')) || [];
      }
      continue;
    }
    
    // FYI bullet: - **[Title](url)** — *Source*
    const fyiMatch = line.match(/^-\s*\*\*\[(.*?)\]\((.*?)\)\*\*\s*—\s*\*(.*?)\*/);
    if (fyiMatch) {
      items.push({
        type: 'fyi',
        content: fyiMatch[1],
        link: fyiMatch[2],
        source: fyiMatch[3],
      });
    }
  }
  
  return items;
}

const sections = parseReport(content);
const formatDate = (dateStr: string) => {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
};

// Get badge class based on emoji
function getBadgeClass(emoji: string) {
  switch (emoji) {
    case '🔴': return 'badge-action';
    case '🟡': return 'badge-watch';
    case '🟢': return 'badge-learn';
    case '📰': return 'badge-fyi';
    default: return '';
  }
}
---

<Layout title={`SEO Digest — ${formatDate(date)}`}>
  <a href="/" class="back">← Back to all reports</a>
  <h1>{formatDate(date)}</h1>
  
  {sections.map(section => {
    const items = parseContent(section.content);
    const badgeClass = getBadgeClass(section.emoji);
    
    if (section.level === 1) return null; // Skip main title
    
    return (
      <div>
        <div class="section-title">
          <span>{section.emoji}</span>
          <span>{section.title}</span>
          {items.length > 0 && <span class={`badge ${badgeClass}`}>{items.length} items</span>}
        </div>
        
        {section.content.includes('require immediate attention') || section.content.includes('monitor these') || section.content.includes('new concepts') || section.content.includes('everything else') ? (
          <p class="subtitle" style="margin-top: -0.5rem; margin-bottom: 1rem;">
            {section.content.split('\n')[0].replace(/^>/, '').trim()}
          </p>
        ) : null}
        
        {items.map(item => (
          <article class="card">
            {item.type === 'article' ? (
              <>
                <h3><a href={item.link} target="_blank" rel="noopener">{item.content}</a></h3>
                <div class="source">{item.source}</div>
                {item.summary && (
                  <div class="summary">
                    {item.summary.replace(/<[^>]+>/g, '').substring(0, 280)}
                    {item.summary.length > 280 ? '...' : ''}
                  </div>
                )}
                {item.tags && item.tags.length > 0 && (
                  <div class="tags">
                    {item.tags.map(tag => <span class="tag-item">{tag}</span>)}
                  </div>
                )}
              </>
            ) : item.type === 'fyi' ? (
              <>
                <h3><a href={item.link} target="_blank" rel="noopener">{item.content}</a></h3>
                <div class="source">{item.source}</div>
              </>
            ) : null}
          </article>
        ))}
      </div>
    );
  })}
</Layout>
